# ──────────────────────────────────────────────────────────────
#  Vanisland AI Marketing Studio — Environment Variables
# ──────────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# When VITE_STUDIO_EXEC_URL is set, all data operations go to
# Google Sheets / Drive via Apps Script.
# When it is absent, the app falls back to localStorage (prototype mode).
#
# See apps-script/README.md for deployment instructions.
# ──────────────────────────────────────────────────────────────

VITE_STUDIO_EXEC_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Vanisland Residential Tenancy Application — Google Form
VITE_RENTAL_FORM_URL=https://docs.google.com/forms/d/YOUR_FORM_ID/viewform

# Admin Studio access code — 6 digits, set your own before deploying.
# Never commit the real code; keep it in .env.local (gitignored).
VITE_ADMIN_ACCESS_CODE=YOUR_6_DIGIT_CODE
